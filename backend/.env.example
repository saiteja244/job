GEMINI_API_KEY=your_gemini_api_key
SARVAM_API_KEY=your_sarvam_api_key

# Recommended if quota errors: gemini-flash-lite-latest
GEMINI_MODEL=gemini-flash-lite-latest

# Speech-to-text language hint for short clips
STT_LANGUAGE_CODE=en-IN

PORT=5000
FLASK_DEBUG=false

# Render: add your Vercel URL(s), comma-separated
# CORS_ORIGINS=https://your-app.vercel.app
# (*.vercel.app is allowed automatically)

# AI voice reply length (~30 sec speech, default 75 words)
VOICE_MAX_WORDS=75
TTS_MAX_WORDS=75
