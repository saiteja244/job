# Local dev: leave empty — Vite proxies /api to backend
VITE_API_URL=

# Local proxy target (backend)
VITE_API_PROXY=http://localhost:5000

# Production (Vercel): set in Project → Settings → Environment Variables
# Example: https://ai-career-backend.onrender.com/api
# VITE_API_URL=https://YOUR-RENDER-SERVICE.onrender.com/api
